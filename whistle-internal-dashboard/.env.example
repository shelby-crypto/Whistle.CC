# ─── Supabase Connection ──────────────────────────────────────────────────
# NEVER commit real values. This file is a template only.
# Copy to .env.local and fill in real values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose to client. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Read replica connection string — dashboard queries go here
DATABASE_URL_READONLY=postgresql://dashboard_reader:password@your-replica-host:5432/whistle_replica

# ─── CISO Finding 2: Anonymization Salt ──────────────────────────────────
# HMAC-SHA256 salt for athlete ID anonymization.
# Must be rotated if ever exposed. 64+ character random string.
ANONYMIZATION_HMAC_SECRET=generate-a-64-char-random-secret-here

# Separate salt for export anonymization (CISO + CPO requirement)
# Prevents correlation between dashboard display and exported datasets
EXPORT_HMAC_SECRET=generate-a-different-64-char-random-secret-here

# ─── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Session Configuration ────────────────────────────────────────────────
# CISO Finding 1: Session parameters
SESSION_MAX_AGE_HOURS=8
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_MAX_CONCURRENT=2

# ─── Rate Limiting ────────────────────────────────────────────────────────
# CISO Finding 5: Rate limit configuration
RATE_LIMIT_GENERAL_PER_MINUTE=60
RATE_LIMIT_EXPORT_PER_HOUR=5
RATE_LIMIT_SEARCH_PER_MINUTE=30
